{
    "jsc": {
        "parser": {
            "syntax": "typescript",
            "decorators": true
        },
        "transform": {
            "legacyDecorator": true,
            "decoratorMetadata": true
        },
        "target": "es2021"
    },
    "module": {
        "type": "es6"
    },
    "sourceMaps": true
}
